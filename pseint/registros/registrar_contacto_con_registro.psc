Algoritmo registrar_contacto_sin_registro
	Definir nombre, telefono, categoria Como Cadena
	Escribir "Ingrese el nombre del contacto:"
	Leer nombre
	Escribir "Ingrese el telefono:"
	Leer telefono
	Escribir "Ingrese la categoria:"
	Leer categoria
	Escribir "===== CONTACTO REGISTRADO ====="
	Escribir "Nombre: ", nombre
	Escribir "Telefono: ", telefono
	Escribir "Categoria: ", categoria
FinAlgoritmo