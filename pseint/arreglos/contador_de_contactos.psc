Algoritmo contador_de_contactos
	Definir nombres Como Cadena
	Definir i, n Como Entero
	Dimension nombres[100]
	n <- 4
	nombres[0] <- "Ana"
	nombres[1] <- "Luis"
	nombres[2] <- "Carlos"
	nombres[3] <- "Maria"
	Escribir "Contando contactos..."
	Para i <- 0 Hasta n-1 Hacer
	FinPara
	Escribir "Total de contactos: ", n
FinAlgoritmo