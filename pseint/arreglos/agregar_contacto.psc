Algoritmo agregar_contacto
	Definir nombres Como Cadena
	Definir telefonos Como Cadena
	Definir n Como Entero
	Dimension nombres[100]
	Dimension telefonos[100]
	n <- 0
	Escribir "Ingrese el nombre del nuevo contacto:"
	Leer nombres[n]
	Escribir "Ingrese el teléfono:"
	Leer telefonos[n]
	n <- n + 1
	Escribir "Contacto agregado correctamente"
FinAlgoritmo