Algoritmo verificar_duplicados
    Definir nombre1, nombre2 Como Cadena
    Escribir "Ingrese el primer nombre:"
    Leer nombre1
    Escribir "Ingrese el segundo nombre:"
    Leer nombre2
    Si nombre1 = nombre2 Entonces
        Escribir "El contacto esta duplicado"
    SiNo
        Escribir "No hay duplicados"
    FinSi
FinAlgoritmo